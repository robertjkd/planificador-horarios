# ================================================
# Django .gitignore
# Planificador de Horarios
# ================================================

# ================================================
# Python
# ================================================
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/
*.egg
MANIFEST

# PyInstaller
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pytest_cache/

# Translations
*.mo
*.pot

# ================================================
# Django
# ================================================
# Base de datos local (SQLite)
db.sqlite3
db.sqlite3-journal

# Archivos de media subidos por usuarios
media/

# Archivos estáticos compilados
staticfiles/
static/dist/
static_root/

# Archivos de configuración local
local_settings.py
settings_local.py

# Archivos de secretos y variables de entorno
.env
.env.local
.env.production
.env.staging

# Archivos de log
*.log
logs/

# Backups
*.bak
*.backup
*~

# ================================================
# Entornos Virtuales
# ================================================
venv/
ENV/
env/
.venv/
virtualenv/

# ================================================
# IDEs y Editores
# ================================================
# VS Code
.vscode/
*.code-workspace
.history/

# PyCharm / IntelliJ
.idea/
*.iml
*.iws
*.ipr

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# Emacs
*~
.#*

# ================================================
# Sistemas Operativos
# ================================================
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msm
*.msp
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
Icon?
etc

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# ================================================
# Dependencias y Paquetes
# ================================================
node_modules/
npm-debug.log
yarn-error.log
package-lock.json
yarn.lock

# ================================================
# Archivos del Proyecto
# ================================================
# Archivos de migración (opcional, descomentar si se desea ignorar)
# **/migrations/*.py
# !**/migrations/__init__.py

# Archivos de carga temporal
uploads/
temp/
tmp/
*.tmp

# Archivos de reportes generados
reports/
exports/
*.pdf
*.xlsx
*.csv

# Archivos de base de datos de desarrollo
*.dump
*.sql

# ================================================
# Herramientas de Desarrollo
# ================================================
# Celery
celerybeat-schedule
celerybeat.pid

# Sphinx documentation
docs/_build/

# PyBuilder
.target/

# Jupyter Notebook
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# ================================================
# Docker
# ================================================
docker-compose.override.yml
.dockerignore

# ================================================
# Excepciones - NUNCA ignorar estos archivos
# ================================================
!.gitkeep
!.gitignore
!requirements.txt
!requirements/
!requirements/*.txt

# ================================================
# Archivos específicos del proyecto (añadir según necesidad)
# ================================================
# Añadir aquí archivos específicos del proyecto si es necesario
