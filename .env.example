# ─────────────────────────────────────────────────────────────
# CONFIGURACIÓN DE BASE DE DATOS
# ─────────────────────────────────────────────────────────────
# Opciones: 'sqlite' (desarrollo rápido) o 'postgresql' (producción)
# Por defecto: sqlite
DB_ENGINE=sqlite

# ─────────────────────────────────────────────────────────────
# CONFIGURACIÓN PARA SQLITE (DB_ENGINE=sqlite)
# ─────────────────────────────────────────────────────────────
# Solo necesitas especificar el nombre del archivo de base de datos
# Por defecto: db.sqlite3
DB_NAME=db.sqlite3

# ─────────────────────────────────────────────────────────────
# CONFIGURACIÓN PARA POSTGRESQL (DB_ENGINE=postgresql)
# ─────────────────────────────────────────────────────────────
# Cuando uses PostgreSQL, configura estas variables adicionales:
# DB_NAME=planificador_db
# DB_USER=postgres
# DB_PASSWORD=tu_contraseña
# DB_HOST=localhost
# DB_PORT=5432

# ─────────────────────────────────────────────────────────────
# CONFIGURACIÓN GENERAL DE DJANGO
# ─────────────────────────────────────────────────────────────
# DEBUG=True para desarrollo, False para producción
DEBUG=True

# SECRET_KEY debe ser único y secreto en producción
# Genera uno con: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-change-me-in-production-abc123

# ALLOWED_HOSTS (separados por comas, sin espacios)
# En producción, agrega tu dominio: example.com,www.example.com
ALLOWED_HOSTS=localhost,127.0.0.1

# ─────────────────────────────────────────────────────────────
# CONFIGURACIÓN DE EMAIL (para alertas de fallos del solver)
# ─────────────────────────────────────────────────────────────
# Opcional: Configura para recibir alertas por correo cuando el solver falle repetidamente
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=tu-email@gmail.com
# EMAIL_HOST_PASSWORD=tu-app-password
# DEFAULT_FROM_EMAIL=noreply@planificador.edu
# ADMIN_EMAIL=vicedecano@planificador.edu

# ─────────────────────────────────────────────────────────────
# CONFIGURACIÓN DE ALERTAS DEL SOLVER
# ─────────────────────────────────────────────────────────────
# SOLVER_FAILURE_THRESHOLD=3  # Número de fallos para enviar alerta
# SOLVER_FAILURE_WINDOW_HOURS=1  # Ventana de tiempo en horas
